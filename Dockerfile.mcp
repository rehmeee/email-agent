# MailMind Workspace MCP image — build yourself, push to YOUR registry.
# Does not depend on Docker Hub or public GHCR pulls of workspace-mcp.
#
# Build:
#   docker build -f Dockerfile.mcp -t mailmind-workspace-mcp:latest .
#
# Run:
#   docker run --rm -p 8000:8000 \
#     -e GOOGLE_OAUTH_CLIENT_ID=... \
#     -e GOOGLE_OAUTH_CLIENT_SECRET=... \
#     -e MCP_ENABLE_OAUTH21=true \
#     -e EXTERNAL_OAUTH21_PROVIDER=true \
#     -e WORKSPACE_MCP_STATELESS_MODE=true \
#     mailmind-workspace-mcp:latest
#
# Push (example Docker Hub):
#   docker tag mailmind-workspace-mcp:latest YOURUSER/mailmind-workspace-mcp:latest
#   docker push YOURUSER/mailmind-workspace-mcp:latest

FROM python:3.12-slim-bookworm

WORKDIR /app

RUN apt-get update \
  && apt-get install -y --no-install-recommends curl ca-certificates git \
  && rm -rf /var/lib/apt/lists/* \
  && pip install --no-cache-dir uv

# Pin to the official GitHub repo (avoids abandoned PyPI name collision).
ARG MCP_GIT_REF=main
RUN uv pip install --system \
  "git+https://github.com/taylorwilsdon/google_workspace_mcp.git@${MCP_GIT_REF}"

RUN useradd --create-home --shell /bin/bash mcp \
  && chown -R mcp:mcp /app
USER mcp

ENV MCP_ENABLE_OAUTH21=true \
    EXTERNAL_OAUTH21_PROVIDER=true \
    WORKSPACE_MCP_STATELESS_MODE=true \
    TOOL_TIER=extended \
    TOOLS="gmail drive calendar sheets docs contacts"

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
  CMD curl -f http://127.0.0.1:8000/health || exit 1

ENTRYPOINT ["workspace-mcp"]
CMD ["--transport", "streamable-http", "--tool-tier", "extended", "--tools", "gmail", "drive", "calendar", "sheets", "docs", "contacts"]
